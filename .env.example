# ============================================================
# TeamGenie AI — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to Git (it's in .gitignore)
# ============================================================

#==========================================
# BACKEND (FastAPI)
#==========================================
NODE_ENV=development
PYTHON_ENV=development
APP_MODE=demo                    # demo | hybrid | production
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true
ALLOWED_ORIGINS=http://localhost:3000,https://teamgenie.app

#==========================================
# DATABASES
#==========================================

# Turso (Primary Database)
TURSO_DATABASE_URL=libsql://teamgenie-XXXXX.turso.io
TURSO_AUTH_TOKEN=eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9...

# Supabase (Auth & Realtime)
SUPABASE_URL=https://XXXXX.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# Upstash Redis (Cache)
UPSTASH_REDIS_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_TOKEN=AXXXXXfasdfasdf

# Pinecone (Vector Database)
PINECONE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=player-embeddings

