#==========================================
# FEATURE FLAGS
#==========================================
ENABLE_AI_FIREWALL=true
ENABLE_SELF_HEALING=true
ENABLE_ANALYTICS=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_RAG=false                 # Requires Pinecone + Cohere/Gemini keys
RATE_LIMIT_FREE_TIER=100
RATE_LIMIT_PAID_TIER=1000
PRIMARY_LLM=gemini-2.0-flash
FALLBACK_LLM=deepseek-v3

#==========================================
# COMPLIANCE
#==========================================
DATA_RETENTION_DAYS=365
COOKIE_CONSENT_REQUIRED=true
FORCE_HTTPS=true
ENABLE_HSTS=true
ENABLE_CSP=true

#==========================================
# AI FIREWALL TUNING (optional)
#==========================================
FIREWALL_MAX_BODY_BYTES=1048576  # 1MB default
FIREWALL_BAN_THRESHOLD=5         # violations before temp IP ban

# ============================================================
# HOW TO GET API KEYS:
# Gemini:    https://makersuite.google.com/app/apikey
# Claude:    https://console.anthropic.com/
# Supabase:  https://supabase.com/dashboard/project/_/settings/api
# Turso:     https://turso.tech/app
# Razorpay:  https://dashboard.razorpay.com/app/keys
# Pinecone:  https://app.pinecone.io
#
# SECURITY BEST PRACTICES:
# 1. NEVER commit .env to Git
# 2. Use different keys for dev/staging/prod
# 3. Rotate secrets every 90 days
# 4. Use Doppler/Infisical in production (not .env files)
# 5. Grant minimum required permissions
# ============================================================
