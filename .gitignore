# ============================================
# TeamGenie AI — .gitignore
# ============================================

# ---------- Dependencies ----------
node_modules/
.pnp/
.pnp.js
bun.lockb

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
venv/
.venv/
env/
.env/
pip-wheel-metadata/

# ---------- Environment Variables ----------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Keep the example
!.env.example
!apps/**/.env.example

# ---------- Build Outputs ----------
.next/
out/
.nuxt/
.turbo/
*.tsbuildinfo

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------- Testing ----------
coverage/
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------- Logs ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- Docker ----------
docker-compose.override.yml

# ---------- Expo / React Native ----------
.expo/
ios/
android/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# ---------- Data (large files) ----------
data/raw/
data/processed/
data/models/
data/embeddings/
*.csv
*.parquet
*.h5
*.pkl
*.joblib

# ---------- Secrets / Certs ----------
*.pem
*.key
*.crt
*.cer
secrets/

# ---------- Misc ----------
.vercel
.render
*.bak
*.tmp
tmp/
